# Supabase — get these from your Supabase project dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to client, server-side only
# Used by admin pages to bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: for Supabase Storage
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=photos
